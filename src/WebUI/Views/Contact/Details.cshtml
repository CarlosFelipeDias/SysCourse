@model WebUI.Models.ContactViewModel

<div>

    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" readonly />
    </div>

    <div class="form-group">
        <label asp-for="Surname"></label>
        <input asp-for="Surname" class="form-control" readonly />
    </div>

    <div class="form-group">
        <label asp-for="Email"></label>
        <input asp-for="Email" class="form-control" readonly />
    </div>

    <a asp-controller="Phone" asp-action="Create" asp-route-contactId="@Model.Id" class="btn btn-secondary mt-2">Add Phone Number</a>
    <a asp-action="Index" class="btn btn-secondary mt-2">Back</a>
</div>
