@model WebUI.Models.ContactViewModel

<div class="container py-4">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <h3 class="mb-3">Delete Contact</h3>
            <p class="text-muted mb-4">Please confirm that you want to remove this contact.</p>

            @if (Model.PhonesList.Count > 0)
            {
                <div class="alert alert-warning" role="alert">
                    This contact has <strong>@Model.PhonesList.Count</strong> associated phone number(s).
                    If you continue, those phone numbers will also be deleted.
                </div>
            }

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label fw-semibold"></label>
                    <input asp-for="Name" class="form-control" readonly />
                </div>

                <div class="col-md-6">
                    <label asp-for="Surname" class="form-label fw-semibold"></label>
                    <input asp-for="Surname" class="form-control" readonly />
                </div>

                <div class="col-md-6">
                    <label asp-for="Email" class="form-label fw-semibold"></label>
                    <input asp-for="Email" class="form-control" readonly />
                </div>
            </div>

            @if (Model.PhonesList.Count > 0)
            {
                <div class="mb-4">
                    <h5 class="mb-3">Associated Phone Numbers</h5>
                    <ul class="list-group">
                        @foreach (var phone in Model.PhonesList)
                        {
                            <li class="list-group-item">@phone.PhoneNumber</li>
                        }
                    </ul>
                </div>
            }

            <form asp-action="Delete" method="post" class="d-flex gap-2">
                <input asp-for="Id" type="hidden" />
                <button type="submit" class="btn btn-danger">Delete Contact</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
