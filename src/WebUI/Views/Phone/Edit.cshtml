@model WebUI.Models.PhoneViewModel

<form asp-action="Edit" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <input asp-for="Id" type="hidden" />
    <input asp-for="ContactId" type="hidden" />

    <div class="form-group">
        <label asp-for="PhoneNumber"></label>
        <input asp-for="PhoneNumber" class="form-control" data-phone-mask placeholder="(11)99999-9999" inputmode="numeric" />
        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary mt-2">
        Save
    </button>

    <a asp-controller="Contact" asp-action="Details" asp-route-id="@Model.ContactId" class="btn btn-secondary mt-2">
        Back
    </a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
